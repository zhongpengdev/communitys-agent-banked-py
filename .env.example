# ─── Claude Agent SDK ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 模型配置（可选，留空使用默认值）
# 主 Agent 模型：claude-opus-4-7 / claude-sonnet-4-6 / claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6
# 标题生成模型（轻量即可）
CLAUDE_TITLE_MODEL=claude-haiku-4-5-20251001
# 自定义 API 地址（使用代理时填写，留空则走官方地址）
ANTHROPIC_BASE_URL=

# ─── 后端服务 ────────────────────────────────────────
PORT=8081
Banked_URL=http://172.20.10.14:8080
Fronted_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/community_agent

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=
JWT_expiration=

# ─── 第三方搜索 API ───────────────────────────────────
SERP_KEY=
DOMAINSDB_KEY=

# ─── 通义万相文生图（可选）────────────────────────────
API_KEY= 
QWEN_CREATE_TEXT_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
QWEN_GET_RESULT_URL=https://dashscope.aliyuncs.com/api/v1/tasks
